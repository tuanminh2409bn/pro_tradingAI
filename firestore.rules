rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Public Data: Tin tức, tín hiệu, phân tích (Ai cũng có thể đọc)
    match /news/{document=**} {
      allow read: if true;
    }
    match /signals/{document=**} {
      allow read: if true;
    }
    match /analytics/{document=**} {
      allow read: if true;
    }

    // 2. User Private Data: Chỉ chủ sở hữu mới có quyền đọc/ghi
    match /accounts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /referrals/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /trades/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Admin: Tạm thời cho phép đọc nếu đã đăng nhập
    match /admin/{document=**} {
      allow read: if request.auth != null;
    }

    // 4. Community & Social: Cho phép mọi người đọc, chỉ người dùng mới có thể đăng bài
    match /community/{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    match /leaderboard/{document=**} {
      allow read: if true;
    }
  }
}
